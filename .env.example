CHECKFLOW_DATABASE_URL=sqlite:///./backend/checkflow.db
# CHECKFLOW_DATABASE_URL=postgresql://checkflow:checkflow@127.0.0.1:5432/checkflow
CHECKFLOW_ENV=development
CHECKFLOW_AUTH_MODE=local
CHECKFLOW_JWT_SECRET=change-me-in-local-env-at-least-32-bytes
# Production must use explicit frontend origins, not "*".
CHECKFLOW_CORS_ORIGINS=*

# IAM / SSO placeholders for future company login integration.
CHECKFLOW_IAM_AUTHORIZE_URL=
CHECKFLOW_IAM_TOKEN_URL=
CHECKFLOW_IAM_PROFILE_URL=
CHECKFLOW_IAM_CLIENT_ID=
CHECKFLOW_IAM_CLIENT_SECRET=
CHECKFLOW_IAM_REDIRECT_URI=
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_AUTH_MODE=local

POSTGRES_DB=checkflow
POSTGRES_USER=checkflow
POSTGRES_PASSWORD=checkflow
